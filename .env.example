# Get these from https://developer.whoop.com after creating your app
WHOOP_CLIENT_ID=your_client_id_here
WHOOP_CLIENT_SECRET=your_client_secret_here

# For local dev:
WHOOP_REDIRECT_URI=http://localhost:5000/callback

# For deployed (update to your actual URL):
# WHOOP_REDIRECT_URI=https://your-app.onrender.com/callback

# Flask secret key (generate a random string for production)
FLASK_SECRET_KEY=change-me-to-a-random-string
